# ─── Dumpr Environment Variables ─────────────────────────────────────────────
# Copy this file to .env and fill in your values

# Supabase (required)
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Tenor GIF API (optional — falls back to demo key for development)
# Get a free key: https://console.cloud.google.com → APIs → enable "Tenor API"
VITE_TENOR_API_KEY=your_tenor_api_key
